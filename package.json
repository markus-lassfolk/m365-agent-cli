{
  "name": "clippy",
  "version": "0.1.1",
  "description": "CLI for Microsoft 365/EWS using OAuth2 refresh token authentication",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markus-lassfolk/clippy.git"
  },
  "bugs": {
    "url": "https://github.com/markus-lassfolk/clippy/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "clippy": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --max-diagnostics=none --diagnostic-level=error .",
    "lint:fix": "biome lint --write --unsafe --diagnostic-level=error .",
    "format": "biome format --write .",
    "format:check": "biome format --max-diagnostics=none .",
    "test": "bun test"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
