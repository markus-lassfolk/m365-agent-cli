{
  "name": "m365-agent-cli",
  "version": "2026.7.6",
  "description": "Microsoft 365 from your terminal: calendar, mail, OneDrive, Planner, Teams, Graph \u2014 one OAuth login",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markus-lassfolk/m365-agent-cli.git"
  },
  "bugs": {
    "url": "https://github.com/markus-lassfolk/m365-agent-cli/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "m365-agent-cli": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "cli:tsx": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --max-diagnostics=none --diagnostic-level=error .",
    "lint:fix": "biome lint --write --unsafe --diagnostic-level=error .",
    "format": "biome format --write .",
    "format:check": "biome format --max-diagnostics=none .",
    "biome:check": "biome check --max-diagnostics=none .",
    "docs:graph-permission-matrix": "tsx scripts/generate-graph-permission-feature-matrix.ts",
    "docs:graph-permission-matrix:check": "tsx scripts/generate-graph-permission-feature-matrix.ts --check",
    "inventory:scripting": "node scripts/cli-json-readonly-inventory.mjs > docs/CLI_SCRIPTING_INVENTORY.md",
    "graph:inventory": "node scripts/graph-call-inventory.mjs --write docs/GRAPH_PATH_INVENTORY.json",
    "graph:inventory:check": "node scripts/graph-call-inventory.mjs --check docs/GRAPH_PATH_INVENTORY.json",
    "verify:graph-openapi": "node scripts/graph-openapi-compliance.mjs",
    "verify:graph-openapi:strict": "GRAPH_OPENAPI_STRICT=1 node scripts/graph-openapi-compliance.mjs",
    "verify:graph-compliance": "node scripts/graph-call-inventory.mjs --check docs/GRAPH_PATH_INVENTORY.json && GRAPH_OPENAPI_STRICT=1 node scripts/graph-openapi-compliance.mjs",
    "verify:cli-help-examples": "node scripts/run-bun-test.mjs test src/test/cli-help-examples-verify.test.ts",
    "embed-sha": "node scripts/embed-git-sha.mjs",
    "sync-skill": "node scripts/sync-skill-version.mjs",
    "install-tools-md": "node scripts/install-tools-md.mjs",
    "install-openclaw-skill": "node scripts/install-openclaw-skill.mjs",
    "test-glitchtip-send": "node scripts/test-glitchtip-send.mjs",
    "knip": "knip",
    "verify:coverage": "node scripts/check-coverage.mjs",
    "verify:coverage:lib": "node scripts/check-coverage-lib.mjs",
    "report:coverage:lib-gaps": "node scripts/report-lib-coverage-gaps.mjs",
    "postinstall": "node scripts/install-openclaw-skill.mjs",
    "test": "node scripts/run-bun-test.mjs test --isolate",
    "test:coverage": "node scripts/run-bun-test.mjs test --isolate --coverage --coverage-reporter=lcov --coverage-reporter=text"
  },
  "files": [
    "src",
    "package.json",
    "LICENSE",
    "CHANGELOG.md",
    "skills/m365-agent-cli/SKILL.md",
    "skills/README.md",
    "packaging/tools-md-snippet.md",
    "scripts/install-tools-md.mjs",
    "scripts/install-openclaw-skill.mjs"
  ],
  "dependencies": {
    "@sentry/node": "^8.55.1",
    "commander": "^12.0.0",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "latest",
    "@types/semver": "^7.5.8",
    "knip": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
