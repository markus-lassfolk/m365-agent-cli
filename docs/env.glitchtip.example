# GlitchTip error reporting — copy to ~/.config/m365-agent-cli/.env (or export in the shell).
# See docs/GLITCHTIP.md for eligibility rules, PII handling, and troubleshooting.
#
# Agent setup: copy this file to ~/.config/m365-agent-cli/.env

# Project DSN (Sentry-compatible; write-only ingest key)
GLITCHTIP_DSN=http://24b38e2af0e04330bc37bc5b45b3ff2e@glitchtip.lassfolk.cc/6

# Explicitly enable (optional; reporting runs when DSN is set unless set to 0/false)
GLITCHTIP_ENABLED=true

# Environment tag on events
GLITCHTIP_ENVIRONMENT=production

# Release tag in GlitchTip: omit to use the running CLI version automatically (m365-agent-cli@X.Y.Z from package.json).
# GLITCHTIP_RELEASE=m365-agent-cli@9.9.9

# --- Optional ---
# GLITCHTIP_SKIP_VERSION_CHECK=1
# GLITCHTIP_ALLOW_UNVERIFIED_COMMIT=1
# GLITCHTIP_DEBUG_ELIGIBILITY=1
# GLITCHTIP_REPORT_ALL=1
